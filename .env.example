# 널널(Nullnull) 환경설정 — 이 파일을 .env로 복사해 값을 채우세요: cp .env.example .env
# 키가 하나도 없어도 데모 모드(시드 스냅샷)로 전 기능이 동작합니다.

# ── 데이터베이스 ──────────────────────────────────────────────
# 기본값: SQLite(개발/데모). 운영은 PostgreSQL 권장(기획서 10-1).
# DATABASE_URL=postgresql+psycopg2://nullnull:password@localhost:5432/nullnull
DATABASE_URL=sqlite:///./nullnull.db

# ── 데모 모드 ────────────────────────────────────────────────
# true  : 외부 API 호출 없이 시드 스냅샷만으로 동작(심사장 오프라인 대비)
# false : 키가 등록된 API는 일배치에서 실데이터 수집
# 미설정 : KTO_API_KEY가 없으면 자동으로 데모 모드
# DEMO_MODE=false

# ── 한국관광공사 OpenAPI (필수 활용 5종 공통 인증키) ──────────
# 공공데이터포털(data.go.kr) 활용신청 후 발급되는 일반 인증키(Decoding)
KTO_API_KEY=

# ── 보조 외부 API (전부 무료) ────────────────────────────────
# 기상청 단기예보(공공데이터포털) — 방문일이 예보 범위(~3일) 내일 때만 날씨 항 적용
KMA_API_KEY=
# 서울 실시간 도시데이터(data.seoul.go.kr) — 서울 집중 MVP의 당일 시간대 분산(F3)
SEOUL_API_KEY=
# 카카오모빌리티 길찾기 REST 키 — 없으면 하버사인 거리 기반 추정으로 폴백
KAKAO_REST_API_KEY=

# ── OpenAI (AI 코스 추천) ────────────────────────────────────
# 키가 없으면 알고리즘 다중 코스로 자동 폴백(오프라인 심사 대비). 발급: platform.openai.com
OPENAI_API_KEY=
# 코스 구성 모델 — 기본은 저비용 gpt-4o-mini. 품질 우선이면 gpt-4o 등으로 상향
OPENAI_MODEL=gpt-4o-mini

# ── 관리자 ──────────────────────────────────────────────────
# /api/admin/* 호출 시 X-Admin-Token 헤더 값 — 배포 시 반드시 변경
ADMIN_TOKEN=nullnull-admin

# ── CORS (FE dev 서버) ──────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
